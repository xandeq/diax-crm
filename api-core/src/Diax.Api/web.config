<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet" arguments=".\Diax.Api.dll" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />
      
      <!-- Remove headers CORS do IIS para evitar conflito com ASP.NET Core -->
      <httpProtocol>
        <customHeaders>
          <remove name="Access-Control-Allow-Origin" />
          <remove name="Access-Control-Allow-Headers" />
          <remove name="Access-Control-Allow-Methods" />
          <remove name="Access-Control-Allow-Credentials" />
        </customHeaders>
      </httpProtocol>
    </system.webServer>
  </location>
</configuration>
