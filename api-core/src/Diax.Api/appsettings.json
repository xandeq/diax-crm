{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/diax-api-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "Jwt": {
    "Issuer": "DiaxCRM",
    "Audience": "DiaxCRM",
    "ExpirationInMinutes": 60,
    "Key": ""
  },
  "Auth": {
    "AdminEmail": "",
    "AdminPassword": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "https://crm.alexandrequeiroz.com.br",
      "http://localhost:3000"
    ]
  },
  "AllowedHosts": "*"
}
