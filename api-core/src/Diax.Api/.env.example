ASPNETCORE_ENVIRONMENT=Development
DIAX_ConnectionStrings__DefaultConnection=Server=localhost;Database=DiaxCRM;User ID=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;Encrypt=true;TrustServerCertificate=true;Connection Timeout=60;
DIAX_JWT__KEY=replace-with-a-strong-random-key
DIAX_JWT__ISSUER=DiaxCRM
DIAX_JWT__AUDIENCE=DiaxCRM
DIAX_AUTH__ADMIN_EMAIL=admin@example.com
DIAX_AUTH__ADMIN_PASSWORD=replace-me
DIAX_CORS__ALLOWEDORIGINS__0=https://crm.example.com
DIAX_CORS__ALLOWEDORIGINS__1=http://localhost:3000
