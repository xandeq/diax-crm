UPDATE ai_models 
SET is_enabled = 0 
WHERE provider_id IN (SELECT id FROM ai_providers WHERE [key] = 'gemini')
AND model_key IN ('gemini-2.0-flash-exp', 'gemini-exp-1206', 'gemini-1.5-pro', 'gemini-1.5-flash')
2026-02-05 20:43:56.358 -03:00 [INF] Executed DbCommand (4ms) [Parameters=[], CommandType='"Text"', CommandTimeout='60']

IF NOT EXISTS (SELECT 1 FROM ai_providers WHERE [key] = 'google')
BEGIN
    UPDATE ai_providers SET [key] = 'google' WHERE [key] = 'gemini'
END
2026-02-05 20:43:56.380 -03:00 [INF] Executed DbCommand (16ms) [Parameters=[], CommandType='"Text"', CommandTimeout='60']

DECLARE @ProviderId UNIQUEIDENTIFIER
SELECT @ProviderId = id FROM ai_providers WHERE [key] = 'google' OR [key] = 'gemini'

IF @ProviderId IS NOT NULL
BEGIN
    IF NOT EXISTS (SELECT 1 FROM ai_models WHERE provider_id = @ProviderId AND model_key = 'gemini-2.5-flash')
    BEGIN
        INSERT INTO ai_models (id, provider_id, model_key, display_name, is_enabled, is_discovered)
        VALUES (NEWID(), @ProviderId, 'gemini-2.5-flash', 'Gemini 2.5 Flash', 1, 0)
    END

    IF NOT EXISTS (SELECT 1 FROM ai_models WHERE provider_id = @ProviderId AND model_key = 'gemini-2.0-flash')
    BEGIN
        INSERT INTO ai_models (id, provider_id, model_key, display_name, is_enabled, is_discovered)
        VALUES (NEWID(), @ProviderId, 'gemini-2.0-flash', 'Gemini 2.0 Flash', 1, 0)
    END
    ELSE
    BEGIN
        UPDATE ai_models SET is_enabled = 1 WHERE provider_id = @ProviderId AND model_key = 'gemini-2.0-flash'
    END

    IF NOT EXISTS (SELECT 1 FROM ai_models WHERE provider_id = @ProviderId AND model_key = 'gemini-flash-latest')
    BEGIN
        INSERT INTO ai_models (id, provider_id, model_key, display_name, is_enabled, is_discovered)
        VALUES (NEWID(), @ProviderId, 'gemini-flash-latest', 'Gemini Flash Latest', 1, 0)
    END

    IF NOT EXISTS (SELECT 1 FROM ai_models WHERE provider_id = @ProviderId AND model_key = 'gemini-pro-latest')
    BEGIN
        INSERT INTO ai_models (id, provider_id, model_key, display_name, is_enabled, is_discovered)
        VALUES (NEWID(), @ProviderId, 'gemini-pro-latest', 'Gemini Pro Latest', 1, 0)
    END

    IF NOT EXISTS (SELECT 1 FROM ai_models WHERE provider_id = @ProviderId AND model_key = 'gemma-3-4b-it')
    BEGIN
        INSERT INTO ai_models (id, provider_id, model_key, display_name, is_enabled, is_discovered)
        VALUES (NEWID(), @ProviderId, 'gemma-3-4b-it', 'Gemma 3 4B IT', 1, 0)
    END

    IF NOT EXISTS (SELECT 1 FROM ai_models WHERE provider_id = @ProviderId AND model_key = 'gemma-3-12b-it')
    BEGIN
        INSERT INTO ai_models (id, provider_id, model_key, display_name, is_enabled, is_discovered)
        VALUES (NEWID(), @ProviderId, 'gemma-3-12b-it', 'Gemma 3 12B IT', 1, 0)
    END
END
