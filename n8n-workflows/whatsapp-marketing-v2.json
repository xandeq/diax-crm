    {
      "parameters": {
        "jsCode": "const result = $input.first().json;\nconst sent = result.sentCount ?? 0;\nconst skipped = result.skippedCount ?? 0;\nconst failed = result.failedCount ?? 0;\nconsole.log(`[WhatsApp Campanha] Enviados: ${sent} | Pulados: ${skipped} | Falhas: ${failed}`);\nif (result.skippedReasons && result.skippedReasons.length > 0) {\n  console.log(`[WhatsApp Campanha] Motivos pulados: ${result.skippedReasons.join('; ')}`);\n}\nif (result.failedReasons && result.failedReasons.length > 0) {\n  console.log(`[WhatsApp Campanha] Motivos falhas: ${result.failedReasons.join('; ')}`);\n}\nreturn [{ json: { success: true, sent, skipped, failed, result } }];"
      },
