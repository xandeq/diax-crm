# ─────────────────────────────────────────────
# DIAX Blog Generator — Variáveis de Ambiente
# Copie este arquivo como .env e preencha os valores
# ─────────────────────────────────────────────

# OpenAI API Key (gpt-4o + dall-e-3)
OPENAI_API_KEY=sk-...

# URL base da sua API (sem barra final)
DIAX_API_URL=https://api.alexandrequeiroz.com.br

# Bearer token JWT para autenticar na API
# Gere em: POST /api/v1/auth/login
DIAX_API_TOKEN=eyJ...

# Caminho para o arquivo JSON da Service Account do Google
# (veja README.md para como criar)
GOOGLE_SA_JSON_PATH=/opt/diax-blog/service_account.json

# ID da pasta do Google Drive onde salvar as imagens
# (já configurado com sua pasta)
GOOGLE_DRIVE_FOLDER_ID=1vv-w8rR4ew0oyhj4vI2ArXYjBR6EaI8W

# Nome do autor dos posts
AUTHOR_NAME=Alexandre Queiroz
